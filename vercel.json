{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/api/category-competitors",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600, stale-while-revalidate=60"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/auth/google", "destination": "/api" },
    { "source": "/oauth2callback", "destination": "/api" },
    { "source": "/app.js", "destination": "/api" },
    { "source": "/styles.css", "destination": "/api" },
    { "source": "/assets/(.*)", "destination": "/api" },
    { "source": "/", "destination": "/api" }
  ]
}